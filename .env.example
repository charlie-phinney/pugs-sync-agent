# Pugs Sync Agent — local Mac config

# Where to POST scraped iMessage data
PUGS_SYNC_WEBHOOK_URL=https://pugs-sales.vercel.app/api/import/imessage

# Shared secret. Must match PUGS_SYNC_SECRET env var on Vercel.
# Charlie sets this on both sides before handing the agent to Connor.
PUGS_SYNC_SECRET=replace-me-with-a-long-random-string

# Local port for the outbound iMessage sender HTTP listener
SENDER_PORT=7890

# How far back to scrape on first run (in days). After first run we track
# last_rowid in state.json so this only applies to the initial backfill.
INITIAL_BACKFILL_DAYS=90

# Optional: override the chat.db path. Default is ~/Library/Messages/chat.db
# CHAT_DB_PATH=/Users/connor/Library/Messages/chat.db
