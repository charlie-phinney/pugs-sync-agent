<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.pugs.syncagent.updater</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__AGENT_ROOT__/update.sh</string>
  </array>

  <!-- Check for updates every 10 minutes -->
  <key>StartInterval</key>
  <integer>600</integer>
  <key>RunAtLoad</key>
  <true/>

  <!-- Updater is the lifeline — if it dies, we have no remote recovery
       path. Auto-restart on any bad exit. -->
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>Crashed</key>
    <true/>
  </dict>
  <key>ThrottleInterval</key>
  <integer>30</integer>

  <key>StandardOutPath</key>
  <string>__AGENT_ROOT__/updater.log</string>
  <key>StandardErrorPath</key>
  <string>__AGENT_ROOT__/updater.error.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
